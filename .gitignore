# ==========================================================
# Java / Spring Boot / Maven / IntelliJ IDEA .gitignore
# ==========================================================

# =========================
# Build Output
# =========================
target/
build/
out/

# =========================
# Maven
# =========================
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# =========================
# Gradle
# =========================
.gradle/

# =========================
# Logs
# =========================
*.log
logs/
hs_err_pid*
replay_pid*

# =========================
# Environment Files (Secrets)
# =========================
.env
.env.*
!.env.example

# =========================
# Application Secrets
# =========================
application-local.properties
application-local.yml
application-secret.properties
application-secret.yml

# =========================
# IDE - IntelliJ IDEA
# =========================
.idea/
*.iml
*.ipr
*.iws

# =========================
# IDE - Eclipse / STS
# =========================
.project
.classpath
.settings/
.springBeans
.sts4-cache/

# =========================
# IDE - VS Code
# =========================
.vscode/

# =========================
# NetBeans
# =========================
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db
Desktop.ini

# =========================
# Temporary Files
# =========================
*.tmp
*.temp
*.swp
*~

# =========================
# Java Compiled Files
# =========================
*.class
*.jar
*.war
*.ear

# Keep Maven Wrapper JAR tracked if you use Maven Wrapper
!.mvn/wrapper/maven-wrapper.jar